API_PORT=3001
FRONTEND_PORT=8090
MONZO_REDIRECT_URI=http://localhost:3001/api/auth/monzo/callback
VAULT_PATH=.vault/monzo.vault.enc
FRONTEND_URL=http://localhost:8090

# Tailnet / mobile access (optional — see README “Mobile / Tailnet access”)
# DEV_PUBLIC_HOST=mybox.tail12345.ts.net
# MOBILE_HOST=m.mybox.tail12345.ts.net
# ENABLE_TAILSCALE_SERVE=1
# VUE_DEV_HMR_EXPLICIT=1

# Automation scheduler (backend runs these without the dashboard open)
AUTO_TRIGGER_INTERVAL_MS=60000
AUTO_TRIGGER_TIMEZONE=Europe/London
